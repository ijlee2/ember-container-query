{
  "name": "docs-app",
  "version": "3.1.0",
  "private": true,
  "description": "docs-app for ember-container-query",
  "keywords": [
    "container-queries",
    "container-query",
    "element-queries",
    "element-query",
    "ember-octane",
    "emberjs",
    "glint",
    "responsive-design"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ijlee2/ember-container-query.git"
  },
  "license": "MIT",
  "author": "Isaac J. Lee",
  "exports": {
    "./tests/*": "./tests/*",
    "./*": "./app/*"
  },
  "directories": {
    "doc": "doc",
    "test": "tests"
  },
  "scripts": {
    "build": "vite build && ./post-build.sh",
    "build:test": "NODE_ENV=development vite build --mode development",
    "format": "prettier . --cache --write",
    "lint": "concurrently \"pnpm:lint:*(!fix)\" --names \"lint:\"",
    "lint:css": "stylelint \"app/**/*.css\" --cache",
    "lint:css:fix": "stylelint \"app/**/*.css\" --fix",
    "lint:fix": "concurrently \"pnpm:lint:*:fix\" --names \"fix:\" && pnpm format",
    "lint:format": "prettier . --cache --check",
    "lint:js": "eslint . --cache",
    "lint:js:fix": "eslint . --fix",
    "prelint:types": "type-css-modules --src app",
    "lint:types": "ember-tsc --noEmit",
    "start": "vite",
    "test": "pnpm build:test && DEVICE=\"w3-h3\" NODE_ENV=development ember test --test-port=0",
    "test:device": "NODE_ENV=development ember test"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/plugin-transform-runtime": "^7.29.7",
    "@babel/plugin-transform-typescript": "^7.29.7",
    "@ember/optional-features": "^3.0.0",
    "@ember/string": "^4.0.1",
    "@ember/test-helpers": "^5.4.3",
    "@embroider/compat": "^4.1.21",
    "@embroider/config-meta-loader": "^1.0.0",
    "@embroider/core": "^4.6.2",
    "@embroider/legacy-inspector-support": "^0.1.3",
    "@embroider/macros": "^1.20.5",
    "@embroider/router": "^3.0.6",
    "@embroider/vite": "^1.7.8",
    "@glimmer/component": "^2.1.1",
    "@glimmer/tracking": "^1.1.2",
    "@glint/ember-tsc": "^1.8.11",
    "@glint/template": "^1.7.8",
    "@glint/tsserver-plugin": "^2.5.17",
    "@percy/cli": "^1.32.3",
    "@percy/ember": "^5.0.1",
    "@rollup/plugin-babel": "^7.1.0",
    "@shared-configs/eslint-config-ember": "workspace:*",
    "@shared-configs/prettier": "workspace:*",
    "@shared-configs/stylelint": "workspace:*",
    "@shared-configs/typescript": "workspace:*",
    "@types/qunit": "^2.19.14",
    "axe-core": "^4.12.1",
    "broccoli-asset-rev": "^3.0.0",
    "concurrently": "^10.0.3",
    "d3-array": "^3.2.4",
    "d3-axis": "^3.0.0",
    "d3-scale": "^4.0.2",
    "d3-selection": "^3.0.0",
    "d3-shape": "^3.2.0",
    "decorator-transforms": "^2.4.0",
    "ember-a11y-refocus": "^5.2.1",
    "ember-a11y-testing": "^8.0.1",
    "ember-cli": "~7.1.0",
    "ember-cli-babel": "^8.3.1",
    "ember-cli-htmlbars": "^7.0.1",
    "ember-container-query": "workspace:*",
    "ember-load-initializers": "^3.0.1",
    "ember-modifier": "^4.3.0",
    "ember-page-title": "^9.0.3",
    "ember-primitives": "^0.60.0",
    "ember-qunit": "^9.1.0",
    "ember-resolver": "^13.2.0",
    "ember-source": "~7.1.0",
    "ember-svg-jar": "^2.7.1",
    "ember-template-imports": "^4.4.0",
    "ember-truth-helpers": "^5.0.0",
    "embroider-css-modules": "^4.0.10",
    "eslint": "^10.6.0",
    "loader.js": "^4.7.0",
    "prettier": "^3.9.4",
    "qunit": "^2.26.0",
    "qunit-dom": "^3.5.1",
    "strip-test-selectors": "^0.1.0",
    "stylelint": "^17.14.0",
    "type-css-modules": "^3.2.7",
    "typescript": "^6.0.3",
    "vite": "^8.1.3"
  },
  "engines": {
    "node": "22.* || >= 24"
  },
  "ember": {
    "edition": "octane"
  },
  "ember-addon": {
    "type": "app",
    "version": 2
  }
}
