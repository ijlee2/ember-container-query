{
  "name": "docs-app",
  "version": "2.2.4",
  "private": true,
  "description": "docs-app for ember-container-query",
  "keywords": [
    "container-queries",
    "container-query",
    "element-queries",
    "element-query",
    "ember-octane",
    "emberjs",
    "glint",
    "responsive-design"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ijlee2/ember-container-query.git"
  },
  "license": "MIT",
  "author": "Isaac J. Lee",
  "directories": {
    "doc": "doc",
    "test": "tests"
  },
  "scripts": {
    "build": "ember build --environment=production",
    "build:test": "ember build --environment=test",
    "format": "prettier . --cache --write",
    "lint": "concurrently \"pnpm:lint:*(!fix)\" --names \"lint:\"",
    "lint:css": "stylelint \"app/**/*.css\" --cache",
    "lint:css:fix": "stylelint \"app/**/*.css\" --fix",
    "lint:fix": "concurrently \"pnpm:lint:*:fix\" --names \"fix:\" && pnpm format",
    "lint:format": "prettier . --cache --check",
    "lint:hbs": "ember-template-lint .",
    "lint:hbs:fix": "ember-template-lint . --fix",
    "lint:js": "eslint . --cache",
    "lint:js:fix": "eslint . --fix",
    "prelint:types": "type-css-modules --src app",
    "lint:types": "ember-tsc --noEmit",
    "start": "ember serve --port=4200",
    "test": "DEVICE=\"w3-h3\" ember test --test-port=0",
    "test:device": "ember test"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@ember/optional-features": "^3.0.0",
    "@ember/string": "^4.0.1",
    "@ember/test-helpers": "^5.4.2",
    "@embroider/broccoli-side-watch": "^1.1.0",
    "@embroider/compat": "^3.9.3",
    "@embroider/config-meta-loader": "^1.0.0",
    "@embroider/core": "^3.5.9",
    "@embroider/legacy-inspector-support": "^0.1.3",
    "@embroider/macros": "^1.20.2",
    "@embroider/router": "^2.1.12",
    "@embroider/webpack": "^4.1.2",
    "@glimmer/component": "^2.1.1",
    "@glimmer/tracking": "^1.1.2",
    "@glint/ember-tsc": "^1.5.0",
    "@glint/template": "^1.7.7",
    "@glint/tsserver-plugin": "^2.4.0",
    "@percy/cli": "^1.31.13",
    "@percy/ember": "^5.0.1",
    "@shared-configs/ember-template-lint": "workspace:*",
    "@shared-configs/eslint-config-ember": "workspace:*",
    "@shared-configs/prettier": "workspace:*",
    "@shared-configs/stylelint": "workspace:*",
    "@shared-configs/typescript": "workspace:*",
    "@types/qunit": "^2.19.13",
    "autoprefixer": "^10.5.0",
    "axe-core": "^4.11.4",
    "broccoli-asset-rev": "^3.0.0",
    "concurrently": "^9.2.1",
    "d3-array": "^3.2.4",
    "d3-axis": "^3.0.0",
    "d3-scale": "^4.0.2",
    "d3-selection": "^3.0.0",
    "d3-shape": "^3.2.0",
    "ember-a11y-refocus": "^5.2.1",
    "ember-a11y-testing": "^8.0.1",
    "ember-auto-import": "^2.13.1",
    "ember-cli": "~6.12.0",
    "ember-cli-app-version": "^7.0.0",
    "ember-cli-babel": "^8.3.1",
    "ember-cli-clean-css": "^3.0.0",
    "ember-cli-htmlbars": "^7.0.1",
    "ember-cli-inject-live-reload": "^2.1.0",
    "ember-cli-netlify": "^0.4.1",
    "ember-container-query": "workspace:*",
    "ember-load-initializers": "^3.0.1",
    "ember-modifier": "^4.3.0",
    "ember-page-title": "^9.0.3",
    "ember-primitives": "^0.57.0",
    "ember-qunit": "^9.0.4",
    "ember-resolver": "^13.2.0",
    "ember-source": "~6.12.0",
    "ember-svg-jar": "^2.7.1",
    "ember-template-imports": "^4.4.0",
    "ember-template-lint": "^7.9.3",
    "ember-test-selectors": "^7.1.0",
    "ember-truth-helpers": "^5.0.0",
    "embroider-css-modules": "^4.0.5",
    "eslint": "^9.39.4",
    "loader.js": "^4.7.0",
    "postcss": "^8.5.14",
    "postcss-loader": "^8.2.1",
    "prettier": "^3.8.3",
    "qunit": "^2.25.0",
    "qunit-dom": "^3.5.1",
    "stylelint": "^17.11.0",
    "type-css-modules": "^3.2.5",
    "typescript": "^5.9.3",
    "webpack": "^5.106.2"
  },
  "engines": {
    "node": "22.* || >= 24"
  },
  "ember": {
    "edition": "octane"
  }
}
